<div class="carousel-container">
    <!-- Image Slides -->
    <div class="carousel-slides">
        <div class="slide active">
            <img src="https://picsum.photos" alt="Slide 1">
        </div>
        <div class="slide">
            <img src="https://picsum.photos" alt="Slide 2">
        </div>
        <div class="slide">
            <img src="https://picsum.photos" alt="Slide 3">
        </div>
    </div>

    <!-- Navigation Buttons -->
    <button class="carousel-btn prev-btn" onclick="moveSlide(-1)">&#10094;</button>
    <button class="carousel-btn next-btn" onclick="moveSlide(1)">&#10095;</button>

    <!-- Indicator Dots -->
    <div class="carousel-dots">
        <span class="dot active" onclick="currentSlide(0)"></span>
        <span class="dot" onclick="currentSlide(1)"></span>
        <span class="dot" onclick="currentSlide(2)"></span>
    </div>
</div>
