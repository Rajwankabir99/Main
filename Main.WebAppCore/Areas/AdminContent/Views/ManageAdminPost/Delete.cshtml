
@model AdminPostViewModel

@{
    ViewBag.Title = "Delete Admin Post";
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.ExcludeHeader = true;
}

<div class="container">
    
    <div id="newAdminPostContainerPartial" class="row card-form">

        <div class="offset-3 col-6">

            <div class="row">

                <div class="col-sm-12 col-md-12 col-xs-12 col-lg-12">

                    <h4 class="card-title all-caps">
                        Are you sure, you want to delete this post?
                    </h4>

                </div>

                <div class="col-sm-12 col-md-12 col-xs-12 col-lg-12 gap"></div>

                <div data-label="Action" class="image-field col-md-12 col-xs-12 col-sm-12 col-lg-12">

                    <a title="List Admin Content"
                            class="icon-button btn-lg flex link-dark"
                            href="@Url.Action("Index", "ManageAdminPost", new { Area = "AdminContent" })">
                        <i class="fa fa-list"></i>
                        <span class="action-text">List</span>
                    </a>

                    <a title="Remove Admin Content"
                        class="icon-button btn-lg flex link-dark"
                            href="@Url.Action("DeleteContent", "ManageAdminPost", new { Area = "AdminContent", id = Model.AdminPostID, fakeId = 1  })">
                        <i class="fa fa-trash"></i>
                        <span class="action-text">Delete</span>
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

