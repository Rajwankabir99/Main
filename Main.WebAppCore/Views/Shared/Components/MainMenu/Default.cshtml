@inject IStringLocalizer<SharedResource> SharedLocalizer

@{
    var adminLinkDisplayClass = "d-none";
    var advertiserLinkDisplayClass = "d-none";
    var isUserSignedClass = "d-none";
    var isShowHomeLabelClass = "d-none";
    string? clientName = "";
    var companyLinkDisplayClass = "d-none";
    var userLinkDisplayClass = "d-none";

    if ( User != null && User.Identity != null && User.Identity.IsAuthenticated )
    {
        
      
        if ( User.IsInRole ( "Admin" ) )
        {
            adminLinkDisplayClass = "d-block";
            advertiserLinkDisplayClass = "d-none";
            companyLinkDisplayClass = "d-none";
            userLinkDisplayClass = "d-none";
            isUserSignedClass = "d-block";
            isShowHomeLabelClass = "d-none";
            string? name = User.Identity.Name;
            clientName = name;
        }
        else if ( User.IsInRole ( "Company" ) )
        {
            adminLinkDisplayClass = "d-none";
            advertiserLinkDisplayClass = "d-none";
            userLinkDisplayClass = "d-none";
            companyLinkDisplayClass = "d-block";
            isUserSignedClass = "d-block";
            isShowHomeLabelClass = "d-none";
            string? name = User.Identity.Name;
            clientName = name;
        }
        else if ( User.IsInRole ( "Advertiser" ) )
        {
            adminLinkDisplayClass = "d-none";
            companyLinkDisplayClass = "d-none";
            userLinkDisplayClass = "d-none";
            advertiserLinkDisplayClass = "d-block";
            isUserSignedClass = "d-block";
            isShowHomeLabelClass = "d-none";
            string? name = User.Identity.Name;
            clientName = name;
        }
        else if ( User.IsInRole ( "User" ) )
        {
            adminLinkDisplayClass = "d-none";
            companyLinkDisplayClass = "d-none";
            advertiserLinkDisplayClass = "d-none";
            userLinkDisplayClass = "d-block";
            isUserSignedClass = "d-block";
            isShowHomeLabelClass = "d-none";
            string? name = User.Identity.Name;
            clientName = name;
        }
        
    }
    else
    {
        adminLinkDisplayClass = "d-none";
        advertiserLinkDisplayClass = "d-none";
        companyLinkDisplayClass = "d-none";
        isUserSignedClass = "d-none";
        isShowHomeLabelClass = "d-block";
        clientName = "";
    }
}

<li>
    <span class="@isShowHomeLabelClass">
        @SharedLocalizer["LabelHi"]
        <a id="ancorSignin_Account"
                href="@Url.Action("Login", "Auth")">
            @SharedLocalizer["LoginSignin"]
        </a>
        /
        <a id="ancorSignup_Account"
                href="@Url.Action("Signup", "Auth")">
            @SharedLocalizer["Register"]
        </a>
    </span>
    <div class="dropdown @isUserSignedClass">
        <a class="dropdown-toggle text-truncate"
                data-toggle="dropdown"
                role="button"
                aria-haspopup="true"
                data-userid="@Model.UserID"
                data-bs-toggle="dropdown">
            <i class="fa fa-user fa-1x"></i>
            <span>@clientName</span>
            <span class="caret"></span>
        </a>
        <ul class="dropdown dropdown-menu" id="divMenuMyHomeSignin">
            <li class="advertiser-menu @advertiserLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-area="Advertizer" asp-controller="AccountSettings" asp-action="ManageAccount">
                    <i class="fa fa-cog fa-fw fa-1x"></i>
                    <span>
                        @SharedLocalizer["LinkManageAccount"]
                    </span>
                </a>
            </li>
            <li class="advertiser-menu @advertiserLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-area="Advertizer" asp-controller="PostLogReport" asp-action="Index">
                                
                    <i class="fa fa-cog fa-fw fa-1x"></i>
                    <span>
                        @SharedLocalizer["LinkBusinessIntelligence"]
                    </span>

                </a>
            </li>
            <li class="advertiser-menu  @advertiserLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-area="Advertizer" asp-controller="ManagePost" asp-action="OnlyPublishedPosts" asp-route-pageNumber="1">
                           
                    <i class="fa fa-cog fa-fw fa-1x"></i>
                        
                    <span>
                        @SharedLocalizer["LinkPublishedPosts"]
                    </span>

                </a>
            </li>
            <li class="advertiser-menu  @advertiserLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-area="Advertizer" asp-controller="FabiaProvider" asp-action="Index" asp-route-pageNumber="1">
                    <i class="fa fa-pencil-alt fa-fw"></i>
                    <span>
                        @SharedLocalizer["LinkMyFabiaServiceProviders"]
                    </span>
                </a>
            </li>



            <li class="admin-menu @adminLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-area="AdminContent" asp-controller="ManageAdminPost" asp-action="Index">
                    <i class="fa fa-cog fa-fw fa-1x"></i>
                    <span>
                        @SharedLocalizer["LinkManageAdminContents"]
                    </span>
                </a>
            </li>
            <li class="admin-menu @adminLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-area="AdminContent" asp-controller="ManageAdminPost" asp-action="NewAdminContent">
                    <i class="fa fa-cog fa-fw fa-1x"></i>
                    <span>
                        @SharedLocalizer["LinkAddShortContent"]
                    </span>
                </a>
            </li>
            <li class="admin-menu @adminLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-area="Admin" asp-controller="ManageFabiaService" asp-action="Index">
                    <i class="fa fa-cog fa-fw fa-1x"></i>
                    <span>
                        @SharedLocalizer["LinkFabiaServices"]
                    </span>
                </a>
            </li>
            <li class="admin-menu @adminLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-area="Admin" asp-controller="Image" asp-action="Index">
                    <i class="fa fa-cog fa-fw fa-1x"></i>
                    <span>
                        @SharedLocalizer["LinkEditImages"]
                    </span>
                </a>
            </li>
            <li class="admin-menu @adminLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-area="PageContent" asp-controller="Pages" asp-action="Index">
                    <i class="fa fa-cog fa-fw fa-1x"></i>
                    <span>
                        @SharedLocalizer["LinkConfigurePanels"]
                    </span>
                </a>
            </li>
            <li class="admin-menu @adminLinkDisplayClass"><hr class="dropdown-divider"></li>        
            <li class="admin-menu @adminLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-area="Admin" asp-controller="PackageConfiguration" asp-action="Index">
                    <i class="fa fa-cog fa-fw fa-1x"></i>
                    <span>
                        @SharedLocalizer["LinkConfigurePackage"]
                    </span>
                </a>
            </li>
            <li class="admin-menu @adminLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-area="Admin" asp-controller="ManageConfiguration" asp-action="Index">
                    <i class="fa fa-cog fa-fw fa-1x"></i>
                    <span>
                        @SharedLocalizer["LinkConfigurePrice"]
                    </span>
                </a>
            </li>
            <li class="admin-menu @adminLinkDisplayClass"><hr class="dropdown-divider"></li>
            <li class="admin-menu @adminLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-area="Admin" asp-controller="BikashBillTransactons" asp-action="Index">
                    <i class="fa fa-cog fa-fw fa-1x"></i>
                    <span>
                        @SharedLocalizer["LinkManageBikashBills"]
                    </span>
                </a>
            </li>          
            <li class="admin-menu @adminLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-area="Report" asp-controller="ApplicationLogReport" asp-action="Index">
                    <i class="fa fa-address-book fa-fw fa-1x"></i>
                    <span>
                        @SharedLocalizer["LinkLogReports"]
                    </span>
                </a>
            </li>



            <li class="company-menu @companyLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-area="Company" asp-controller="CompanySettings" asp-action="ManageAccount">
                    <i class="fa fa-cog fa-fw fa-1x"></i>
                    <span>
                        User Account
                    </span>
                </a> 
            </li> 
            <li class="company-menu @companyLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-area="CompanyContent" asp-controller="ManageProduct" asp-action="Index">
                    <i class="fa fa-cog fa-fw fa-1x"></i>
                    <span>
                            Manage Products
                    </span>
                </a>
            </li> 
            <li class="company-menu @companyLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-area="CompanyContent" asp-controller="ManageProduct" asp-action="NewProduct">
                    <i class="fa fa-cog fa-fw fa-1x"></i>
                    <span>
                            Add New Product
                    </span>
                </a>
            </li>



            <li class="user-menu @userLinkDisplayClass">
                <a class="dropdown-item dropdown-item-text" asp-controller="Account" asp-action="Profile">
                    <i class="fa fa-cog fa-fw fa-1x"></i>
                    <span>
                        Profile
                    </span>
                </a>
            </li>
            <li class="user-menu @userLinkDisplayClass">           
                <a class="dropdown-item dropdown-item-text" asp-controller="Auth" asp-action="ResetPassword">    
                    <i class="fa fa-cog fa-fw fa-1x"></i>
                    <span>
                        Change Password
                    </span>
                </a>
            </li>

            <li><hr class="dropdown-divider"></li>
                            
            <form asp-area="" asp-controller="Auth" asp-action="Logout" method="post" id="logoutForm" class="navbar-right">
                <li>
                    <button type="submit" class="dropdown-item dropdown-item-text"> @SharedLocalizer["LinkLogout"]</button>
                </li>
            </form>
        </ul>
    </div>
</li>
          