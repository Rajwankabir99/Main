@model MenuObjectModel
@inject IStringLocalizer<SharedResource> SharedLocalizer

<div class="top-header">
    <div class="header-container">
        <ul>
            @await Component.InvokeAsync( "MainMenu" )
          
            <li>

            </li>

            <li>

            </li>

            <li>
                <a id="ancor_AllItemMarket_Market" class=""
                       href="@Url.Action("Market", "AllItemMarket", new { pageNumber = "1" })">
                    <i class="fa fa-ad fa-1x link-dark"> </i>
                </a>
            </li>
           
            <li>

            </li>

            <li>
                <a id="ancor_Cart_Product_Shop" class=""
                       href="@Url.Action("GetShoppingCart", "ProductShoppingCart", new { pageNumber = "1" })">
                    <i class="fa fa-shopping-basket fa-1x link-dark"></i>
                </a>
            </li>

        </ul>
    
        <div class="flex-grow"></div>

        <ul>
            <li>
                <div class="dropdown">
                    <a id="ancorMyHelp"
                           href="#"
                           class="dropdown-toggle"
                           data-toggle="dropdown"
                           role="button"
                           aria-haspopup="true"
                           aria-expanded="false"
                           data-bs-toggle="dropdown">
                        <i class="fa fa-info fa-1x"></i>
                        <span class="caret"></span>
                    </a>
                    
                    <ul class="dropdown dropdown-menu" id="divMenuMyHomeHelp">
                        <li>
                            <a id="ancor_FAQ_Home" class="dropdown-item"
                                   href="@Url.Action("FAQ", "Home")">
                                <i class="fa fa-fw fa-question link-dark"></i>
                                <span>@SharedLocalizer["LinkFaq"]</span>
                            </a>
                        </li>
                        <li>
                            <a id="ancor_About_Home" class="dropdown-item"
                                   href="@Url.Action("Resource", "Home")">
                                <i class="fa fa-fw fa-info link-dark"></i>
                                <span>@SharedLocalizer["LinkResources"]</span>
                            </a>
                        </li>
                        <li>
                            <a id="ancor_Contact_Home" class="dropdown-item"
                                   href="@Url.Action("Contact", "Home")">
                                <i class="fa fa-fw fa-phone link-dark"></i>
                                <span>@SharedLocalizer["LinkContact"]</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </li>

            <li></li>

            <li>
                <div class="dropdown">
                    <a id="ancorLanguage"
                           class="dropdown-toggle"
                           data-toggle="dropdown"
                           role="button"
                           aria-haspopup="true"
                           aria-expanded="false"
                           data-bs-toggle="dropdown">
                        <img class="flag" src="~/css/images/flags/uk.png" id="imgEnglishFlag" />
                        <span id="spnEnglishFlag">
                            @SharedLocalizer["LinkEnglish"]
                        </span>
                        <img style="display:none;" class="flag" src="~/css/images/flags/bangladesh.png" id="imgBanglaFlag" />
                        <span style="display:none;" id="spnBanglaFlag">
                            @SharedLocalizer["LinkBangla"]
                        </span>
                        <img style="display:none;" class="flag" src="~/css/images/flags/nigeria.png" id="imgNigeriaFlag" />
                        <span style="display:none;" id="spnNigeriaFlag">
                            @SharedLocalizer["LinkNigeria"]
                        </span>
                        <span class="caret"></span>
                    </a>
                    
                    <ul class="dropdown dropdown-menu">
                        <li>
                            <a id="ancorEnglishLanguage" class="dropdown-item">
                                <img class="flag" src="~/css/images/flags/uk.png" />
                                <span>
                                    @SharedLocalizer["LinkEnglish"]
                                </span>
                            </a>
                        </li>
                        <li>
                            <a id="ancorBanglaLanguage" class="dropdown-item">
                                <img class="flag" src="~/css/images/flags/bangladesh.png" />
                                <span>
                                    @SharedLocalizer["LinkBangla"]
                                </span>
                            </a>
                        </li>
                        <li>
                            <a id="ancorNigeriaLanguage" class="dropdown-item">
                                <img class="flag" src="~/css/images/flags/nigeria.png" />
                                <span>
                                    @SharedLocalizer["LinkNigeria"]
                                </span>
                            </a>
                        </li>
                    </ul>
                </div>
            </li>
        </ul>
    </div>
</div>